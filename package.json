{
  "name": "graduation-campus-app",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "overrides": {
      "@next/eslint-plugin-next": "16.1.7",
      "eslint-config-next": "16.1.7",
      "fast-xml-parser": "^5.5.7",
      "js-yaml": "^4.1.1",
      "next": "16.1.7"
    }
  },
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:mobile": "pnpm --filter mobile start",
    "dev:web": "pnpm --filter web dev",
    "dev:functions": "pnpm --filter functions serve",
    "live-review:file": "node ./scripts/live-file-review.mjs",
    "lint": "pnpm lint:mobile && pnpm lint:web && pnpm lint:functions && pnpm lint:shared",
    "lint:mobile": "pnpm --filter mobile lint",
    "lint:web": "pnpm --filter web lint",
    "lint:functions": "pnpm --filter functions lint",
    "lint:shared": "pnpm --filter @campus/shared lint",
    "typecheck": "pnpm typecheck:mobile && pnpm typecheck:web && pnpm typecheck:shared",
    "typecheck:mobile": "pnpm --filter mobile typecheck",
    "typecheck:web": "pnpm --filter web typecheck",
    "typecheck:shared": "pnpm --filter @campus/shared typecheck",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "firebase": "firebase"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "firebase-tools": "^15.4.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.1"
  }
}
