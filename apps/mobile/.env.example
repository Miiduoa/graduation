#
# Mobile app environment variables
# Copy this file to `.env` before running the app.
#
# cp apps/mobile/.env.example apps/mobile/.env
#

# ---------- App runtime ----------
APP_ENV=development
EXPO_PUBLIC_EAS_PROJECT_ID=

# ---------- Data source mode ----------
# mock | firebase | hybrid
EXPO_PUBLIC_DATA_SOURCE_MODE=mock

# development | staging | production
EXPO_PUBLIC_API_ENV=development

# Hybrid mode behavior
EXPO_PUBLIC_HYBRID_TIMEOUT_MS=10000
EXPO_PUBLIC_HYBRID_FALLBACK_TO_MOCK=true
EXPO_PUBLIC_PREFER_REAL_API=true

# ---------- Firebase ----------
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_CLOUD_FUNCTION_REGION=asia-east1

# ---------- Maps ----------
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# ---------- AI ----------
EXPO_PUBLIC_AI_PROVIDER=cloud

# ---------- Test school login ----------
TEST_SCHOOL_LOGIN_ENABLED=false
TEST_SCHOOL_ID=tw-demo-uni
TEST_SCHOOL_USERNAME=

# ============================================
# Payment Services (Optional)
# ============================================
# Stripe Publishable Key
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key

# TapPay App ID and Key (Taiwan local payments)
EXPO_PUBLIC_TAPPAY_APP_ID=your-tappay-app-id
EXPO_PUBLIC_TAPPAY_APP_KEY=your-tappay-app-key
EXPO_PUBLIC_TAPPAY_SERVER_TYPE=sandbox

# ============================================
# Analytics (Optional)
# ============================================
# Enable analytics tracking
EXPO_PUBLIC_ANALYTICS_ENABLED=true

# ============================================
# Feature Flags
# ============================================
# Enable demo/mock data mode
EXPO_PUBLIC_USE_MOCK_DATA=true

# Enable AR navigation features
EXPO_PUBLIC_AR_ENABLED=true

# Enable voice guidance
EXPO_PUBLIC_VOICE_GUIDANCE_ENABLED=true
