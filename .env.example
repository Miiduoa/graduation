# =============================================================================
# 畢業專題 - 多校園平台 環境變數範本
# =============================================================================
# 
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env
#
# 注意：請勿將 .env 檔案提交至版本控制系統
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase 設定
# -----------------------------------------------------------------------------
# 從 Firebase Console > 專案設定 > 一般 > 您的應用程式 取得這些值
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abc123def456
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin SDK (用於 Cloud Functions)
# 從 Firebase Console > 專案設定 > 服務帳戶 下載 JSON 金鑰
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# -----------------------------------------------------------------------------
# Expo / Mobile App 設定
# -----------------------------------------------------------------------------
# Expo 帳戶 token (用於 CI/CD EAS Build)
# 從 https://expo.dev/accounts/[account]/settings/access-tokens 取得
EXPO_TOKEN=your-expo-token

# App 識別碼
EXPO_PUBLIC_APP_NAME=Campus App
EXPO_PUBLIC_APP_SLUG=campus-app
EXPO_PUBLIC_BUNDLE_IDENTIFIER=com.yourorg.campusapp

# -----------------------------------------------------------------------------
# AI 服務設定
# -----------------------------------------------------------------------------
# OpenAI API Key (用於 AI 助理功能)
# 從 https://platform.openai.com/api-keys 取得
OPENAI_API_KEY=sk-your-openai-api-key

# Google AI (Gemini) API Key
# 從 https://makersuite.google.com/app/apikey 取得
GOOGLE_AI_API_KEY=your-google-ai-api-key

# AI 服務選擇: openai | gemini | mock
AI_PROVIDER=mock

# -----------------------------------------------------------------------------
# 推播通知設定
# -----------------------------------------------------------------------------
# FCM Server Key (已棄用，建議使用 Firebase Admin SDK)
FCM_SERVER_KEY=your-fcm-server-key

# APNs 設定 (iOS 推播)
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apple-team-id

# -----------------------------------------------------------------------------
# SSO 單一登入設定
# -----------------------------------------------------------------------------
# 各校 SSO 設定應依學校分開設定

# 範例：學校 A (OIDC)
SCHOOL_A_SSO_TYPE=oidc
SCHOOL_A_CLIENT_ID=your-client-id
SCHOOL_A_CLIENT_SECRET=your-client-secret
SCHOOL_A_ISSUER_URL=https://sso.school-a.edu.tw
SCHOOL_A_REDIRECT_URI=https://your-app.com/auth/callback

# 範例：學校 B (CAS)
SCHOOL_B_SSO_TYPE=cas
SCHOOL_B_CAS_URL=https://cas.school-b.edu.tw/cas

# 範例：學校 C (SAML)
SCHOOL_C_SSO_TYPE=saml
SCHOOL_C_SAML_ENTRY_POINT=https://idp.school-c.edu.tw/saml2/idp/SSOService.php
SCHOOL_C_SAML_ISSUER=your-saml-issuer
SCHOOL_C_SAML_CERT=./certs/school-c-idp.pem

# -----------------------------------------------------------------------------
# 支付服務設定
# -----------------------------------------------------------------------------
# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret

# TapPay
TAPPAY_PARTNER_KEY=your-tappay-partner-key
TAPPAY_MERCHANT_ID=your-tappay-merchant-id

# Line Pay
LINEPAY_CHANNEL_ID=your-linepay-channel-id
LINEPAY_CHANNEL_SECRET=your-linepay-channel-secret

# 街口支付
JKOPAY_STORE_ID=your-jkopay-store-id
JKOPAY_API_KEY=your-jkopay-api-key

# -----------------------------------------------------------------------------
# 外部服務 API
# -----------------------------------------------------------------------------
# Google Maps (用於地圖功能)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# 公車即時資訊 API
BUS_API_ENDPOINT=https://api.bus-provider.com/v1
BUS_API_KEY=your-bus-api-key

# 圖書館系統 API
LIBRARY_API_ENDPOINT=https://library.school.edu.tw/api
LIBRARY_API_KEY=your-library-api-key

# -----------------------------------------------------------------------------
# 開發/除錯設定
# -----------------------------------------------------------------------------
# 環境: development | staging | production
NODE_ENV=development

# 日誌等級: debug | info | warn | error
LOG_LEVEL=debug

# 啟用 Mock 資料 (開發用)
USE_MOCK_DATA=true

# 啟用除錯模式
DEBUG_MODE=true

# Sentry 錯誤回報 (可選)
SENTRY_DSN=https://xxx@sentry.io/xxx

# -----------------------------------------------------------------------------
# Web App 設定 (Next.js)
# -----------------------------------------------------------------------------
# 這些變數需要 NEXT_PUBLIC_ 前綴才能在客戶端使用
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# 網站 URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# 測試設定
# -----------------------------------------------------------------------------
# 測試用 Firebase 模擬器端口
FIREBASE_EMULATOR_AUTH_PORT=9099
FIREBASE_EMULATOR_FIRESTORE_PORT=8080
FIREBASE_EMULATOR_FUNCTIONS_PORT=5001
FIREBASE_EMULATOR_STORAGE_PORT=9199

# 測試用帳號
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=testpassword123

# ─── App Store Submission ────────────────────────────────────────
APPLE_ID=your-apple-id@example.com
ASC_APP_ID=1234567890
APPLE_TEAM_ID=XXXXXXXXXX
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-play-service-account.json

# ─── Legal URLs ──────────────────────────────────────────────────
EXPO_PUBLIC_LEGAL_BASE_URL=https://your-domain.com/legal
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://your-domain.com/legal/privacy
EXPO_PUBLIC_TERMS_URL=https://your-domain.com/legal/terms

# ─── Error Reporting ─────────────────────────────────────────────
EXPO_PUBLIC_ERROR_REPORTING_ENDPOINT=https://your-sentry-dsn-here
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn-here

# ─── Deep Links ──────────────────────────────────────────────────
EXPO_PUBLIC_DEEP_LINK_HOST=campus-app.example.com

# ─── Feature Flags (production) ─────────────────────────────────
EXPO_PUBLIC_FEATURE_SSO=true
EXPO_PUBLIC_FEATURE_COURSES=true
EXPO_PUBLIC_FEATURE_GRADES=true
EXPO_PUBLIC_FEATURE_PAYMENTS=false
EXPO_PUBLIC_FEATURE_WIDGETS=true
EXPO_PUBLIC_FEATURE_DEEPLINKS=true
EXPO_PUBLIC_RELEASED_SCHOOL_IDS=school_a,school_b

# ─── Google Maps ─────────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
