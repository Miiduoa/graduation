# ============================================
# Firebase Functions Configuration
# ============================================

# Firebase project configuration (auto-configured in most cases)
GCLOUD_PROJECT=your-project-id
FIREBASE_CONFIG={"projectId":"your-project-id"}

# ============================================
# Push Notifications
# ============================================
# FCM Server Key (for legacy HTTP v1 API)
FCM_SERVER_KEY=your-fcm-server-key

# ============================================
# External APIs
# ============================================
# OpenAI API Key (for backend-managed AI proxy)
OPENAI_API_KEY=sk-your-openai-api-key

# Optional Gemini backend key
GEMINI_API_KEY=

# ============================================
# SSO Configuration
# ============================================
# AES-256 key for encrypting SSO secret config (32-byte raw key, base64 or hex)
SSO_CONFIG_ENCRYPTION_KEY=

# Comma-separated trusted web origins for SSO/admin HTTP endpoints
ALLOWED_WEB_ORIGINS=https://your-app.web.app,https://your-app.firebaseapp.com

# ============================================
# Payment Webhooks
# ============================================
# Stripe Webhook Secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Line Pay webhook / channel secrets
LINE_PAY_CHANNEL_ID=
LINE_PAY_CHANNEL_SECRET=

# ============================================
# Email Service (Optional)
# ============================================
# SendGrid API Key for email notifications
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@your-domain.com
