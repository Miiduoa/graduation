rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isValidDocument() {
      return request.resource.contentType.matches('application/pdf')
          || request.resource.contentType.matches('application/msword')
          || request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.*')
          || request.resource.contentType.matches('text/.*');
    }

    function isAllowedUpload() {
      return isValidImage() || isValidDocument();
    }

    function maxSize(mb) {
      return request.resource.size < mb * 1024 * 1024;
    }

    function hasSchoolEditorRole(schoolId) {
      return isAuthenticated()
        && firestore.exists(/databases/(default)/documents/schools/$(schoolId)/members/$(request.auth.uid))
        && (
          firestore.get(/databases/(default)/documents/schools/$(schoolId)/members/$(request.auth.uid)).data.role == 'admin'
          || firestore.get(/databases/(default)/documents/schools/$(schoolId)/members/$(request.auth.uid)).data.role == 'editor'
        )
        && firestore.get(/databases/(default)/documents/schools/$(schoolId)/members/$(request.auth.uid)).data.status == 'active';
    }

    function isGroupMember(groupId) {
      return isAuthenticated()
        && firestore.exists(/databases/(default)/documents/groups/$(groupId)/members/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.status == 'active';
    }

    function canManageGroup(groupId) {
      return isGroupMember(groupId)
        && (
          firestore.get(/databases/(default)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'admin'
          || firestore.get(/databases/(default)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'owner'
          || firestore.get(/databases/(default)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'instructor'
          || firestore.get(/databases/(default)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'moderator'
        );
    }

    function conversationMember(conversationId) {
      return isAuthenticated()
        && firestore.exists(/databases/(default)/documents/conversations/$(conversationId))
        && request.auth.uid in firestore.get(/databases/(default)/documents/conversations/$(conversationId)).data.memberIds;
    }

    function assignmentGroupId(assignmentId) {
      return firestore.get(/databases/(default)/documents/assignments/$(assignmentId)).data.groupId;
    }

    function submissionOwner(assignmentId, userId) {
      return isOwner(userId)
        && firestore.exists(/databases/(default)/documents/assignments/$(assignmentId))
        && isGroupMember(assignmentGroupId(assignmentId));
    }

    function canManageEventAsset(eventId) {
      return isAuthenticated()
        && firestore.exists(/databases/(default)/documents/events/$(eventId))
        && hasSchoolEditorRole(firestore.get(/databases/(default)/documents/events/$(eventId)).data.schoolId);
    }

    function canManageAnnouncementAsset(announcementId) {
      return isAuthenticated()
        && firestore.exists(/databases/(default)/documents/announcements/$(announcementId))
        && hasSchoolEditorRole(firestore.get(/databases/(default)/documents/announcements/$(announcementId)).data.schoolId);
    }

    function canManageMenuAsset(menuId) {
      return isAuthenticated()
        && firestore.exists(/databases/(default)/documents/menus/$(menuId))
        && hasSchoolEditorRole(firestore.get(/databases/(default)/documents/menus/$(menuId)).data.schoolId);
    }

    function canManagePoiAsset(poiId) {
      return isAuthenticated()
        && firestore.exists(/databases/(default)/documents/pois/$(poiId))
        && hasSchoolEditorRole(firestore.get(/databases/(default)/documents/pois/$(poiId)).data.schoolId);
    }

    function canAccessRepairRequest(requestId) {
      return isAuthenticated()
        && firestore.exists(/databases/(default)/documents/repairRequests/$(requestId))
        && (
          firestore.get(/databases/(default)/documents/repairRequests/$(requestId)).data.userId == request.auth.uid
          || isAdmin()
        );
    }

    match /avatars/{userId}.{extension} {
      allow read: if true;
      allow write: if isOwner(userId) && isValidImage() && maxSize(5);
    }

    match /groups/{groupId}/cover.{extension} {
      allow read: if isGroupMember(groupId);
      allow write: if canManageGroup(groupId) && isValidImage() && maxSize(5);
    }

    match /groups/{groupId}/posts/{postId}/{fileName} {
      allow read: if isGroupMember(groupId);
      allow write: if isGroupMember(groupId) && isAllowedUpload() && maxSize(20);
    }

    match /assignments/{assignmentId}/submissions/{userId}/{fileName} {
      allow read: if submissionOwner(assignmentId, userId) || canManageGroup(assignmentGroupId(assignmentId));
      allow write: if submissionOwner(assignmentId, userId) && isAllowedUpload() && maxSize(50);
    }

    match /lostfound/{itemId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidImage() && maxSize(10);
    }

    match /printjobs/{userId}/{jobId}/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidDocument() && maxSize(100);
    }

    match /announcements/{announcementId}/{fileName} {
      allow read: if true;
      allow write: if canManageAnnouncementAsset(announcementId) && isAllowedUpload() && maxSize(20);
    }

    match /events/{eventId}/cover.{extension} {
      allow read: if true;
      allow write: if canManageEventAsset(eventId) && isValidImage() && maxSize(10);
    }

    match /events/{eventId}/gallery/{fileName} {
      allow read: if true;
      allow write: if canManageEventAsset(eventId) && isValidImage() && maxSize(10);
    }

    match /menus/{menuId}/image.{extension} {
      allow read: if true;
      allow write: if canManageMenuAsset(menuId) && isValidImage() && maxSize(5);
    }

    match /pois/{poiId}/{fileName} {
      allow read: if true;
      allow write: if canManagePoiAsset(poiId) && isValidImage() && maxSize(10);
    }

    match /conversations/{conversationId}/messages/{messageId}/{fileName} {
      allow read: if conversationMember(conversationId);
      allow write: if conversationMember(conversationId) && isAllowedUpload() && maxSize(20);
    }

    match /bugreports/{reportId}/{fileName} {
      allow read: if isAdmin();
      allow write: if isAuthenticated() && isValidImage() && maxSize(10);
    }

    match /repairs/{requestId}/{fileName} {
      allow read: if canAccessRepairRequest(requestId);
      allow write: if canAccessRepairRequest(requestId) && isValidImage() && maxSize(10);
    }

    match /health/{userId}/{recordId}/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if (isOwner(userId) || isAdmin()) && isAllowedUpload() && maxSize(20);
    }

    match /temp/{userId}/{fileName} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && maxSize(50);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
