rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isSchoolMember(schoolId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/schools/$(schoolId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/schools/$(schoolId)/members/$(request.auth.uid)).data.status == 'active';
    }

    function hasAnyServiceRole(schoolId, uid) {
      return exists(/databases/$(database)/documents/schools/$(schoolId)/serviceRoles/$(uid))
        && get(/databases/$(database)/documents/schools/$(schoolId)/serviceRoles/$(uid)).data.status != 'inactive'
        && (
          get(/databases/$(database)/documents/schools/$(schoolId)/serviceRoles/$(uid)).data.orders == true
          || get(/databases/$(database)/documents/schools/$(schoolId)/serviceRoles/$(uid)).data.repairs == true
          || get(/databases/$(database)/documents/schools/$(schoolId)/serviceRoles/$(uid)).data.packages == true
          || get(/databases/$(database)/documents/schools/$(schoolId)/serviceRoles/$(uid)).data.printing == true
          || get(/databases/$(database)/documents/schools/$(schoolId)/serviceRoles/$(uid)).data.health == true
        );
    }

    function hasServiceRoleDomain(schoolId, uid, domain) {
      return exists(/databases/$(database)/documents/schools/$(schoolId)/serviceRoles/$(uid))
        && get(/databases/$(database)/documents/schools/$(schoolId)/serviceRoles/$(uid)).data.status != 'inactive'
        && get(/databases/$(database)/documents/schools/$(schoolId)/serviceRoles/$(uid)).data[domain] == true;
    }

    function isCafeteriaOperator(schoolId, cafeteriaId, uid) {
      return cafeteriaId is string
        && exists(/databases/$(database)/documents/schools/$(schoolId)/cafeterias/$(cafeteriaId)/operators/$(uid))
        && get(/databases/$(database)/documents/schools/$(schoolId)/cafeterias/$(cafeteriaId)/operators/$(uid)).data.status != 'inactive';
    }

    function hasRole(schoolId, role) {
      return isSchoolMember(schoolId)
        && get(/databases/$(database)/documents/schools/$(schoolId)/members/$(request.auth.uid)).data.role == role;
    }

    function hasEditorRole(schoolId) {
      return hasRole(schoolId, 'admin') || hasRole(schoolId, 'editor');
    }

    function requesterHasAnyServiceRole(schoolId) {
      return isSignedIn() && hasAnyServiceRole(schoolId, request.auth.uid);
    }

    function requesterHasServiceRoleDomain(schoolId, domain) {
      return isSignedIn() && hasServiceRoleDomain(schoolId, request.auth.uid, domain);
    }

    function requesterIsCafeteriaOperator(schoolId, cafeteriaId) {
      return isSignedIn() && isCafeteriaOperator(schoolId, cafeteriaId, request.auth.uid);
    }

    function isActiveGroupMember(groupId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.status == 'active';
    }

    function canManageGroup(groupId) {
      return isActiveGroupMember(groupId)
        && (
          get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'admin'
          || get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'owner'
          || get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'instructor'
          || get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'moderator'
        );
    }

    function isConversationMember(conversationId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/conversations/$(conversationId))
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberIds;
    }

    function canReadGroupPost(postId) {
      return exists(/databases/$(database)/documents/groupPosts/$(postId))
        && isActiveGroupMember(get(/databases/$(database)/documents/groupPosts/$(postId)).data.groupId);
    }

    function canReadAssignment(assignmentId) {
      return exists(/databases/$(database)/documents/assignments/$(assignmentId))
        && isActiveGroupMember(get(/databases/$(database)/documents/assignments/$(assignmentId)).data.groupId);
    }

    function canManageAssignment(assignmentId) {
      return exists(/databases/$(database)/documents/assignments/$(assignmentId))
        && canManageGroup(get(/databases/$(database)/documents/assignments/$(assignmentId)).data.groupId);
    }

    function submissionOwnerId(data, submissionId) {
      return data.userId != null
        ? data.userId
        : data.uid != null
          ? data.uid
          : data.studentId != null
            ? data.studentId
            : submissionId;
    }

    function isSubmissionOwner(data, submissionId) {
      return isSignedIn() && request.auth.uid == submissionOwnerId(data, submissionId);
    }

    function isAssignedReviewer(groupId, assignmentId, submissionId, data) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/groups/$(groupId)/assignments/$(assignmentId)/peerReviews/$(request.auth.uid))
        && get(/databases/$(database)/documents/groups/$(groupId)/assignments/$(assignmentId)/peerReviews/$(request.auth.uid)).data.submissionOwnerId
          == submissionOwnerId(data, submissionId);
    }

    function canReadSubmissionDoc(groupId, assignmentId, submissionId, data) {
      return canManageGroup(groupId)
        || isSubmissionOwner(data, submissionId)
        || isAssignedReviewer(groupId, assignmentId, submissionId, data);
    }

    function canReadPeerReviewDoc(groupId, assignmentId, reviewerId, data) {
      return canManageGroup(groupId)
        || (isSignedIn() && reviewerId == request.auth.uid)
        || (isSignedIn() && data.submissionOwnerId == request.auth.uid && data.submittedAt != null);
    }

    // School directory (public readable)
    match /schools/{schoolId} {
      allow read: if true;
      allow write: if false; // managed by admins via functions later

      match /directory/{uid} {
        allow read: if isSchoolMember(schoolId);
        allow write: if false;
      }

      match /members/{uid} {
        allow read: if isSelf(uid) || hasEditorRole(schoolId) || requesterHasAnyServiceRole(schoolId);
        allow write: if false;
      }

      match /serviceRoles/{uid} {
        allow read: if isSelf(uid) || hasEditorRole(schoolId);
        allow write: if false;
      }

      match /cafeterias/{cafeteriaId} {
        allow read: if true;
        allow create, update, delete: if hasEditorRole(schoolId);

        match /operators/{uid} {
          allow read: if isSelf(uid) || hasEditorRole(schoolId);
          allow create, update, delete: if hasEditorRole(schoolId);
        }
      }

      match /announcements/{docId} {
        allow read: if true;
        allow create, update, delete: if false;
      }

      match /pois/{docId} {
        allow read: if true;
        allow create, update, delete: if hasEditorRole(schoolId);

        match /reviews/{reviewId} {
          allow read: if true;
          allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
          allow update, delete: if hasEditorRole(schoolId)
            || (isSignedIn() && resource.data.uid == request.auth.uid);
        }

        match /crowdReports/{reportId} {
          allow read: if true;
          allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
          allow update, delete: if false;
        }

        match /reports/{reportId} {
          allow read: if hasRole(schoolId, 'admin') || hasRole(schoolId, 'editor');
          allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
          allow update: if hasRole(schoolId, 'admin') || hasRole(schoolId, 'editor');
          allow delete: if false;
        }
      }

      match /events/{docId} {
        allow read: if true;
        allow create, update, delete: if false;

        match /registrations/{registrationId} {
          allow read: if hasEditorRole(schoolId)
            || (isSignedIn() && (
              registrationId == request.auth.uid
              || resource.data.userId == request.auth.uid
            ));
          allow create: if isSignedIn()
            && registrationId == request.auth.uid
            && request.resource.data.userId == request.auth.uid;
          allow update: if false;
          allow delete: if isSignedIn()
            && registrationId == request.auth.uid
            && resource.data.userId == request.auth.uid;
        }

        match /reviews/{reviewId} {
          allow read: if true;
          allow create: if isSignedIn()
            && reviewId == request.auth.uid
            && request.resource.data.uid == request.auth.uid;
          allow update, delete: if hasEditorRole(schoolId)
            || (isSignedIn() && resource.data.uid == request.auth.uid);
        }
      }

      match /clubEvents/{docId} {
        allow read: if true;
        allow create, update, delete: if false;
      }

      match /menus/{docId} {
        allow read: if true;
        allow create, update, delete: if hasEditorRole(schoolId);

        match /reviews/{reviewId} {
          allow read: if true;
          allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
          allow update, delete: if hasEditorRole(schoolId)
            || (isSignedIn() && resource.data.uid == request.auth.uid);
        }
      }

      match /cafeteriaMenus/{docId} {
        allow read: if true;
        allow create, update, delete: if hasEditorRole(schoolId);
      }

      match /busRoutes/{docId} {
        allow read: if true;
        allow create, update, delete: if hasEditorRole(schoolId);
      }

      match /busArrivals/{docId} {
        allow read: if true;
        allow write: if false;
      }

      match /libraryBooks/{docId} {
        allow read: if true;
        allow create, update, delete: if hasEditorRole(schoolId);
      }

      match /librarySeats/{docId} {
        allow read: if true;
        allow create, update, delete: if hasEditorRole(schoolId);
      }

      match /libraryLoans/{loanId} {
        allow read: if hasEditorRole(schoolId) || (isSignedIn() && resource.data.userId == request.auth.uid);
        allow write: if false;
      }

      match /seatReservations/{reservationId} {
        allow read: if hasEditorRole(schoolId) || (isSignedIn() && resource.data.userId == request.auth.uid);
        allow write: if false;
      }

      match /lostFound/{docId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }

      match /orders/{orderId} {
        allow read: if hasEditorRole(schoolId)
          || requesterIsCafeteriaOperator(schoolId, resource.data.cafeteriaId)
          || (isSignedIn() && resource.data.userId == request.auth.uid);
        allow create: if false;
        allow update: if hasEditorRole(schoolId)
          || requesterIsCafeteriaOperator(schoolId, resource.data.cafeteriaId)
          || (
            isSignedIn()
            && resource.data.userId == request.auth.uid
            && request.resource.data.userId == resource.data.userId
            && request.resource.data.schoolId == resource.data.schoolId
            && request.resource.data.status == 'cancelled'
          );
        allow delete: if false;
      }

      match /settings/{docId} {
        allow read: if hasRole(schoolId, 'admin');
        allow write: if false;
      }

      match /leaderboard/{docId} {
        allow read: if true;
        allow write: if false;
      }

      match /repairRequests/{requestId} {
        allow read: if hasEditorRole(schoolId) || (isSignedIn() && resource.data.userId == request.auth.uid);
        allow write: if false;
      }

      match /packages/{packageId} {
        allow read: if hasEditorRole(schoolId) || (isSignedIn() && resource.data.recipientId == request.auth.uid);
        allow write: if false;
      }

      match /washingMachines/{machineId} {
        allow read: if true;
        allow create, update, delete: if hasEditorRole(schoolId);
      }

      match /washingReservations/{reservationId} {
        allow read: if hasEditorRole(schoolId) || (isSignedIn() && resource.data.userId == request.auth.uid);
        allow write: if false;
      }

      match /printers/{printerId} {
        allow read: if true;
        allow create, update, delete: if hasEditorRole(schoolId);
      }

      match /printJobs/{jobId} {
        allow read: if hasEditorRole(schoolId) || (isSignedIn() && resource.data.userId == request.auth.uid);
        allow write: if false;
      }

      match /healthAppointments/{appointmentId} {
        allow read: if hasEditorRole(schoolId) || (isSignedIn() && resource.data.userId == request.auth.uid);
        allow write: if false;
      }

      match /healthRecords/{recordId} {
        allow read: if hasEditorRole(schoolId) || (isSignedIn() && resource.data.userId == request.auth.uid);
        allow write: if false;
      }

      match /healthTimeSlots/{slotId} {
        allow read: if true;
        allow create, update, delete: if hasEditorRole(schoolId);
      }

      match /adminLogs/{docId} {
        allow read: if hasEditorRole(schoolId);
        allow write: if false;
      }
    }

    // Conversations (DMs and group chats)
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.schoolId != null
        && isSchoolMember(request.resource.data.schoolId);
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.memberIds
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.memberIds == resource.data.memberIds;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() 
          && exists(/databases/$(database)/documents/conversations/$(conversationId))
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberIds;
        allow create: if isSignedIn()
          && exists(/databases/$(database)/documents/conversations/$(conversationId))
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberIds
          && request.resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn()
          && exists(/databases/$(database)/documents/conversations/$(conversationId))
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberIds
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['readBy'])
          && request.auth.uid in request.resource.data.readBy;
        allow delete: if false;
      }
    }

    // Groups
    match /groups/{groupId} {
      allow read: if isActiveGroupMember(groupId);
      allow create: if isSignedIn()
        && request.resource.data.schoolId != null
        && isSchoolMember(request.resource.data.schoolId);
      allow update: if canManageGroup(groupId) && request.resource.data.schoolId == resource.data.schoolId;
      allow delete: if canManageGroup(groupId);

      match /members/{uid} {
        allow read: if isActiveGroupMember(groupId);
        allow create: if false;
        allow update: if canManageGroup(groupId);
        allow delete: if canManageGroup(groupId);
      }

      match /posts/{postId} {
        allow read: if isActiveGroupMember(groupId);
        allow create: if isActiveGroupMember(groupId)
          && (request.resource.data.kind != 'announcement' || canManageGroup(groupId));
        allow update, delete: if canManageGroup(groupId) || (isSignedIn() && resource.data.authorId == request.auth.uid);

        match /comments/{commentId} {
          allow read: if isActiveGroupMember(groupId);
          allow create: if isActiveGroupMember(groupId);
          allow update, delete: if canManageGroup(groupId) || (isSignedIn() && resource.data.authorId == request.auth.uid);
        }
      }

      match /knowledgeBase/{entryId} {
        allow read: if isActiveGroupMember(groupId);
        allow create, update, delete: if canManageGroup(groupId);
      }

      match /modules/{moduleId} {
        allow read: if isActiveGroupMember(groupId);
        allow create, update, delete: if canManageGroup(groupId);

        match /materials/{materialId} {
          allow read: if isActiveGroupMember(groupId);
          allow create, update, delete: if canManageGroup(groupId);
        }
      }

      match /quizzes/{quizId} {
        allow read: if isActiveGroupMember(groupId);
        allow create, update, delete: if canManageGroup(groupId);
      }

      match /assignments/{assignmentId} {
        allow read: if isActiveGroupMember(groupId);
        allow create, update, delete: if canManageGroup(groupId);

        match /submissions/{submissionId} {
          allow read: if canReadSubmissionDoc(groupId, assignmentId, submissionId, resource.data);
          allow create: if isActiveGroupMember(groupId) && isSubmissionOwner(request.resource.data, submissionId);
          allow update: if canManageGroup(groupId) || isSubmissionOwner(resource.data, submissionId);
          allow delete: if false;
        }

        match /peerReviews/{reviewerId} {
          allow read: if canReadPeerReviewDoc(groupId, assignmentId, reviewerId, resource.data);
          allow create: if canManageGroup(groupId)
            && request.resource.data.reviewerId == reviewerId;
          allow update: if canManageGroup(groupId)
            || (
              isSignedIn()
              && reviewerId == request.auth.uid
              && request.resource.data.reviewerId == resource.data.reviewerId
              && request.resource.data.submissionOwnerId == resource.data.submissionOwnerId
            );
          allow delete: if canManageGroup(groupId);
        }
      }

      match /gradebook/{entryId} {
        allow read: if canManageGroup(groupId)
          || (isSignedIn() && (
            entryId == request.auth.uid
            || resource.data.userId == request.auth.uid
          ));
        allow create, update, delete: if canManageGroup(groupId);
      }

      match /milestones/{milestoneId} {
        allow read: if isActiveGroupMember(groupId);
        allow create, update, delete: if canManageGroup(groupId);
      }

      match /liveSessions/{sessionId} {
        allow read: if isActiveGroupMember(groupId);
        allow create, update, delete: if canManageGroup(groupId);

        match /questions/{questionId} {
          allow read: if isActiveGroupMember(groupId);
          allow create: if isActiveGroupMember(groupId);
          allow update: if canManageGroup(groupId)
            || (
              isActiveGroupMember(groupId)
              && request.resource.data.text == resource.data.text
              && request.resource.data.createdAt == resource.data.createdAt
              && request.resource.data.answered == resource.data.answered
            );
          allow delete: if canManageGroup(groupId);
        }

        match /polls/{pollId} {
          allow read: if isActiveGroupMember(groupId);
          allow create, update, delete: if canManageGroup(groupId);
        }
      }

      match /attendanceSessions/{sessionId} {
        allow read: if isActiveGroupMember(groupId);
        allow create, update, delete: if canManageGroup(groupId);

        match /attendanceRecords/{recordId} {
          allow read: if isActiveGroupMember(groupId);
          allow create, update: if canManageGroup(groupId) || (isSignedIn() && recordId == request.auth.uid);
          allow delete: if false;
        }
      }
    }

    // User profiles
    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create: if isSelf(uid)
        && (request.resource.data.role == null || request.resource.data.role == 'student')
        && request.resource.data.balance == null;
      allow update: if isSelf(uid)
        && request.resource.data.role == resource.data.role
        && request.resource.data.balance == resource.data.balance
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.primarySchoolId == resource.data.primarySchoolId
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;

      match /pushTokens/{tokenId} {
        allow read, write: if isSelf(uid);
      }

      match /settings/{settingId} {
        allow read, write: if isSelf(uid);
      }

      match /schools/{schoolId} {
        allow read: if isSelf(uid);
        allow write: if false;

        match /favorites/{favoriteId} {
          allow read, create, delete: if isSelf(uid);
          allow update: if false;
        }

        match /achievements/{achievementId} {
          allow read, write: if isSelf(uid);
        }

        match /enrollments/{enrollmentId} {
          allow read, write: if isSelf(uid);
        }

        match /grades/{gradeId} {
          allow read: if isSelf(uid);
          allow write: if isSelf(uid);
        }

        match /creditAudit/{docId} {
          allow read: if isSelf(uid);
          allow write: if isSelf(uid);
        }

        match /courses/{courseId} {
          allow read: if isSelf(uid);
          allow write: if isSelf(uid);
        }

        match /calendarEvents/{eventId} {
          allow read, write: if isSelf(uid);
        }

        match /libraryLoans/{loanId} {
          allow read, write: if isSelf(uid);
        }

        match /seatReservations/{reservationId} {
          allow read, write: if isSelf(uid);
        }

        match /orders/{orderId} {
          allow read: if isSelf(uid);
          allow create, update: if isSelf(uid) && request.resource.data.userId == request.auth.uid;
          allow delete: if false;
        }

        match /transactions/{transactionId} {
          allow read: if isSelf(uid);
          allow write: if false;
        }

        match /wallet/{walletDocId} {
          allow read: if isSelf(uid);
          allow write: if false;
        }

        match /weeklyReports/{reportId} {
          allow read: if isSelf(uid);
          allow write: if false;
        }

        match /dailyBriefs/{briefId} {
          allow read: if isSelf(uid);
          allow write: if false;
        }

        match /{document=**} {
          allow read: if isSelf(uid);
          allow write: if false;
        }
      }

      match /groups/{groupRef} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      match /milestones/{milestoneId} {
        allow read: if isSignedIn() && (
          request.auth.uid == uid
          || (resource.data.groupId != null && canManageGroup(resource.data.groupId))
        );
        allow create: if isSignedIn() && (
          request.auth.uid == uid
          || (request.resource.data.groupId != null && canManageGroup(request.resource.data.groupId))
        );
        allow update: if isSignedIn() && (
          request.auth.uid == uid
          || (request.resource.data.groupId != null && canManageGroup(request.resource.data.groupId))
          || (resource.data.groupId != null && canManageGroup(resource.data.groupId))
        );
        allow delete: if false;
      }

      // 學分試算：使用者自己的修課紀錄（子集合）
      match /enrollments/{enrollmentId} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      match /achievements/{achievementId} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      match /notifications/{notificationId} {
        allow read, update, delete: if isSelf(uid);
        allow create: if false;
      }

      match /weeklyReports/{reportId} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      match /dailyBriefs/{briefId} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      match /grades/{gradeId} {
        allow read: if isSelf(uid);
        allow write: if false;
      }
    }

    // SSO Links (internal, no client access)
    match /ssoLinks/{linkId} {
      allow read, write: if false;
    }

    // Admins collection
    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // Global announcements, events, pois, menus (multi-tenant at root level)
    match /announcements/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /events/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /eventRegistrations/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /pois/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /menus/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /menuRatings/{docId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.menuItemId == resource.data.menuItemId;
      allow delete: if false;
    }

    // Courses
    match /courses/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Enrollments
    match /enrollments/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
      allow delete: if false;
    }

    // Grades
    match /grades/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Group Posts (global collection for simplicity)
    match /groupPosts/{docId} {
      allow read: if canReadGroupPost(docId);
      allow write: if false;
    }

    match /postLikes/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && canReadGroupPost(request.resource.data.postId);
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && canReadGroupPost(resource.data.postId);
      allow update: if false;
    }

    // Comments
    match /comments/{docId} {
      allow read: if canReadGroupPost(resource.data.postId);
      allow write: if false;
    }

    // Assignments (global collection)
    match /assignments/{docId} {
      allow read: if isActiveGroupMember(resource.data.groupId);
      allow write: if false;
    }

    // Submissions
    match /submissions/{docId} {
      allow read: if isSubmissionOwner(resource.data, docId)
        || (
          resource.data.groupId != null
          && canManageGroup(resource.data.groupId)
        )
        || (
          resource.data.groupId != null
          && resource.data.assignmentId != null
          && isAssignedReviewer(resource.data.groupId, resource.data.assignmentId, docId, resource.data)
        );
      allow write: if false;
    }

    // Group Members (global collection)
    match /groupMembers/{docId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || isActiveGroupMember(resource.data.groupId)
      );
      allow create: if false;
      allow update: if canManageGroup(resource.data.groupId)
        && request.resource.data.groupId == resource.data.groupId
        && request.resource.data.userId == resource.data.userId;
      allow delete: if false;
    }

    // Messages
    match /messages/{docId} {
      allow read: if isConversationMember(resource.data.conversationId);
      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid
        && isConversationMember(request.resource.data.conversationId);
      allow update: if isConversationMember(resource.data.conversationId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['readBy', 'updatedAt'])
        && request.auth.uid in request.resource.data.readBy;
      allow delete: if false;
    }

    // Lost & Found (global)
    match /lostFoundItems/{docId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Library
    match /libraryBooks/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /libraryLoans/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
      allow delete: if false;
    }

    match /librarySeats/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /seatReservations/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Bus Routes
    match /busRoutes/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /busArrivals/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Notifications
    match /notifications/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if false;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['readAt', 'isRead', 'updatedAt']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Calendar Events
    match /calendarEvents/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Orders
    match /orders/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Transactions
    match /transactions/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Achievements
    match /achievements/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /userAchievements/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Favorites
    match /favorites/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
  }
}
